{
  "tests": [
    {
      "name": "Send OTP valid phone",
      "method": "POST",
      "path": "/",
      "body": {"action": "send_otp", "phone": "+79991234567"},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Send OTP invalid phone",
      "method": "POST",
      "path": "/",
      "body": {"action": "send_otp", "phone": "12"},
      "expectedStatus": 400,
      "expectedBody": {"error": "Некорректный номер телефона"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Verify OTP wrong code",
      "method": "POST",
      "path": "/",
      "body": {"action": "verify_otp", "phone": "+79991234567", "code": "000000"},
      "expectedStatus": 400,
      "expectedBody": {"error": "Неверный или истёкший код"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Get me unauthorized",
      "method": "POST",
      "path": "/",
      "body": {"action": "me"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Не авторизован"},
      "bodyMatcher": "partial"
    }
  ]
}